---
/**
 * RichText Component
 * Renders Lexical editor content from Payload CMS
 * Simplified version - renders basic text nodes
 */

interface Props {
  content: any; // Lexical JSON structure
  class?: string;
}

const { content, class: className = '' } = Astro.props;

// Recursively render Lexical nodes
function renderNode(node: any): string {
  if (!node) return '';

  // Text node
  if (node.type === 'text') {
    let text = node.text || '';

    // Apply formatting
    if (node.format) {
      if (node.format & 1) text = `<strong>${text}</strong>`; // Bold
      if (node.format & 2) text = `<em>${text}</em>`; // Italic
      if (node.format & 4) text = `<s>${text}</s>`; // Strikethrough
      if (node.format & 8) text = `<u>${text}</u>`; // Underline
      if (node.format & 16) text = `<code>${text}</code>`; // Code
    }

    return text;
  }

  // Paragraph
  if (node.type === 'paragraph') {
    const children = node.children?.map(renderNode).join('') || '';
    return `<p>${children}</p>`;
  }

  // Headings
  if (node.type === 'heading') {
    const level = node.tag || 'h2';
    const children = node.children?.map(renderNode).join('') || '';
    return `<${level}>${children}</${level}>`;
  }

  // Quote
  if (node.type === 'quote') {
    const children = node.children?.map(renderNode).join('') || '';
    return `<blockquote>${children}</blockquote>`;
  }

  // List
  if (node.type === 'list') {
    const tag = node.listType === 'number' ? 'ol' : 'ul';
    const children = node.children?.map(renderNode).join('') || '';
    return `<${tag}>${children}</${tag}>`;
  }

  // List item
  if (node.type === 'listitem') {
    const children = node.children?.map(renderNode).join('') || '';
    return `<li>${children}</li>`;
  }

  // Link
  if (node.type === 'link') {
    const children = node.children?.map(renderNode).join('') || '';
    const url = node.url || '#';
    const target = node.newTab ? ' target="_blank" rel="noopener noreferrer"' : '';
    return `<a href="${url}"${target}>${children}</a>`;
  }

  // Linebreak
  if (node.type === 'linebreak') {
    return '<br>';
  }

  // For any other node type, try to render children
  if (node.children) {
    return node.children.map(renderNode).join('');
  }

  return '';
}

// Render the root content
let html = '';
if (content && content.root && content.root.children) {
  html = content.root.children.map(renderNode).join('\n');
}
---

<div class={`rich-text ${className}`} set:html={html} />

<style>
  .rich-text {
    color: var(--color-text-secondary);
    line-height: var(--line-relaxed);
  }

  .rich-text > :global(* + *) {
    margin-top: var(--space-6);
  }

  .rich-text :global(p) {
    font-size: var(--text-lg);
    margin: 0;
  }

  .rich-text :global(h1),
  .rich-text :global(h2),
  .rich-text :global(h3),
  .rich-text :global(h4),
  .rich-text :global(h5),
  .rich-text :global(h6) {
    color: var(--color-text-primary);
    font-weight: var(--font-bold);
    line-height: var(--line-tight);
    margin: var(--space-8) 0 var(--space-4);
  }

  .rich-text :global(h1) { font-size: var(--text-4xl); }
  .rich-text :global(h2) { font-size: var(--text-3xl); }
  .rich-text :global(h3) { font-size: var(--text-2xl); }
  .rich-text :global(h4) { font-size: var(--text-xl); }
  .rich-text :global(h5) { font-size: var(--text-lg); }
  .rich-text :global(h6) { font-size: var(--text-base); }

  .rich-text :global(a) {
    color: var(--color-accent-primary);
    text-decoration: underline;
    text-decoration-color: rgba(79, 125, 247, 0.3);
    text-underline-offset: 2px;
    transition: all var(--transition-base);
  }

  .rich-text :global(a:hover) {
    text-decoration-color: var(--color-accent-primary);
  }

  .rich-text :global(strong) {
    font-weight: var(--font-bold);
    color: var(--color-text-primary);
  }

  .rich-text :global(em) {
    font-style: italic;
  }

  .rich-text :global(code) {
    background: rgba(79, 125, 247, 0.1);
    color: var(--color-accent-primary);
    padding: 0.125rem 0.375rem;
    border-radius: var(--radius-sm);
    font-family: 'Courier New', monospace;
    font-size: 0.9em;
  }

  .rich-text :global(blockquote) {
    padding-left: var(--space-6);
    border-left: 4px solid var(--color-accent-primary);
    font-style: italic;
    color: var(--color-text-secondary);
    margin: var(--space-8) 0;
  }

  .rich-text :global(ul),
  .rich-text :global(ol) {
    padding-left: var(--space-8);
    margin: var(--space-6) 0;
  }

  .rich-text :global(li) {
    margin: var(--space-2) 0;
  }

  .rich-text :global(li::marker) {
    color: var(--color-accent-primary);
  }

  @media (max-width: 768px) {
    .rich-text :global(p) {
      font-size: var(--text-base);
    }

    .rich-text :global(h1) { font-size: var(--text-3xl); }
    .rich-text :global(h2) { font-size: var(--text-2xl); }
    .rich-text :global(h3) { font-size: var(--text-xl); }
    .rich-text :global(h4) { font-size: var(--text-lg); }
  }
</style>
