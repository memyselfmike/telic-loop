---
interface Props {
  class?: string;
  hoverable?: boolean;
}

const { class: className = '', hoverable = true } = Astro.props;
---

<div class={`card ${hoverable ? 'card-hoverable' : ''} ${className}`}>
  <slot />
</div>

<style>
  .card {
    background: rgba(18, 18, 26, 0.6);
    border: 1px solid rgba(79, 125, 247, 0.15);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    backdrop-filter: blur(10px);
    transition: all var(--transition-base);
    position: relative;
    overflow: hidden;
  }

  /* Glass-morphism gradient overlay */
  .card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--gradient-card);
    opacity: 0;
    transition: opacity var(--transition-base);
    pointer-events: none;
    z-index: 0;
  }

  .card > :global(*) {
    position: relative;
    z-index: 1;
  }

  .card-hoverable:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: rgba(79, 125, 247, 0.3);
  }

  .card-hoverable:hover::before {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .card {
      padding: var(--space-6);
    }
  }

  @media (max-width: 480px) {
    .card {
      padding: var(--space-4);
    }
  }
</style>
