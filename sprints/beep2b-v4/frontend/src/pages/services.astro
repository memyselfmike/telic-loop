---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Badge from '../components/Badge.astro';
import Button from '../components/Button.astro';
import SectionDivider from '../components/SectionDivider.astro';

// Services from PRD
const services = [
  {
    number: '01',
    id: 'linkedin-marketing',
    title: 'LinkedIn Marketing',
    description: 'Done-for-you LinkedIn outreach that fills your pipeline with qualified B2B leads every month',
    benefits: [
      'Profile optimization to position you as the authority in your niche',
      'Precision-targeted connection building with your ideal customer profile',
      'Personalized conversation sequences that start real relationships',
      'Monthly reporting with full transparency on outreach and response metrics',
      'Dedicated account manager who knows your business and prospects',
      'Ongoing strategy refinement based on what resonates with your audience'
    ]
  },
  {
    number: '02',
    id: 'thought-leadership',
    title: 'Thought Leadership Marketing',
    description: 'Establish yourself as the go-to expert in your industry through strategic content and engagement',
    benefits: [
      'Content strategy tailored to your expertise and target audience',
      'Ghostwritten LinkedIn articles that showcase your unique insights',
      'Engagement campaigns that build visibility and credibility',
      'LinkedIn newsletter setup and growth to build a subscriber base',
      'Post scheduling and consistency management',
      'Performance tracking and content optimization'
    ]
  },
  {
    number: '03',
    id: 'training',
    title: 'LinkedIn Training',
    description: 'Empower your team to generate their own leads with comprehensive BEEP methodology training',
    benefits: [
      'Half-day or full-day workshops customized to your industry',
      'Complete BEEP methodology playbook and implementation guides',
      'Profile audits for every team member with optimization recommendations',
      'Hands-on practice sessions with real prospect scenarios',
      'Post-training coaching and support for 30 days',
      'Train-the-trainer options for scaling across larger teams'
    ]
  }
];
---

<BaseLayout title="Services - LinkedIn Lead Generation | Beep2B">
  <!-- Hero Banner -->
  <Section>
    <div class="page-hero" data-animate="fade-in">
      <Badge variant="primary">What We Offer</Badge>
      <h1 class="page-title">Our Services</h1>
      <p class="page-intro">
        Whether you need a done-for-you solution, want to build thought leadership, or prefer to train your team — we have a service that fits your business.
      </p>
    </div>
  </Section>

  <SectionDivider />

  <!-- Services -->
  {services.map((service, index) => (
    <>
      <Section background={index % 2 === 1 ? 'elevated' : undefined}>
        <div class="service-block" id={service.id} data-animate="fade-in">
          <div class="service-header">
            <div class="service-number">{service.number}</div>
            <div class="service-title-group">
              <Badge variant={index === 0 ? 'primary' : index === 1 ? 'accent' : 'secondary'}>
                Service {service.number}
              </Badge>
              <h2 class="service-title">{service.title}</h2>
              <p class="service-description">{service.description}</p>
            </div>
          </div>

          <div class="service-benefits" data-stagger>
            <h3 class="benefits-heading">What's Included:</h3>
            <ul class="benefits-list">
              {service.benefits.map(benefit => (
                <li class="benefit-item" data-animate="slide-up">
                  <span class="benefit-icon">✓</span>
                  <span class="benefit-text">{benefit}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="service-cta">
            <Button href="/contact" variant="primary" size="lg">
              Book a Discovery Call
            </Button>
            <Button href="/how-it-works" variant="secondary" size="lg">
              Learn Our Methodology
            </Button>
          </div>
        </div>
      </Section>
      {index < services.length - 1 && <SectionDivider />}
    </>
  ))}

  <SectionDivider variant="thick" />

  <!-- Bottom CTA -->
  <Section background="elevated">
    <div class="bottom-cta" data-animate="fade-in">
      <h2 class="bottom-cta-heading">Not Sure Which Service is Right for You?</h2>
      <p class="bottom-cta-text">
        Book a free discovery call and we'll recommend the best approach based on your goals, budget, and timeline.
      </p>
      <Button href="/contact" variant="primary" size="lg">
        Schedule Your Call Now
      </Button>
    </div>
  </Section>
</BaseLayout>

<style>
  /* === PAGE HERO === */
  .page-hero {
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
    padding: var(--space-12) 0;
  }

  .page-title {
    font-size: var(--text-5xl);
    font-weight: var(--font-black);
    color: var(--color-text-primary);
    margin: var(--space-4) 0;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
  }

  .page-intro {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  /* === SERVICE BLOCK === */
  .service-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
    scroll-margin-top: 100px; /* For anchor links */
  }

  .service-header {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-8);
    align-items: start;
  }

  .service-number {
    font-size: var(--text-8xl);
    font-weight: var(--font-black);
    color: rgba(79, 125, 247, 0.15);
    line-height: 1;
    min-width: 120px;
  }

  .service-title-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .service-title {
    font-size: var(--text-4xl);
    font-weight: var(--font-black);
    color: var(--color-text-primary);
    margin: 0;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
  }

  .service-description {
    font-size: var(--text-xl);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
    font-weight: var(--font-medium);
  }

  /* === SERVICE BENEFITS === */
  .service-benefits {
    background: var(--gradient-card);
    border-radius: var(--radius-xl);
    padding: var(--space-10);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .benefits-heading {
    font-size: var(--text-2xl);
    font-weight: var(--font-bold);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-6) 0;
  }

  .benefits-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .benefit-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-4);
    background: rgba(79, 125, 247, 0.05);
    border-radius: var(--radius-md);
    transition: all var(--transition-base);
  }

  .benefit-item:hover {
    background: rgba(79, 125, 247, 0.1);
    transform: translateX(4px);
  }

  .benefit-icon {
    font-size: var(--text-xl);
    color: var(--color-accent-primary);
    font-weight: var(--font-bold);
    flex-shrink: 0;
    line-height: 1.5;
  }

  .benefit-text {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  /* === SERVICE CTA === */
  .service-cta {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
    padding-top: var(--space-6);
  }

  /* === BOTTOM CTA === */
  .bottom-cta {
    text-align: center;
    padding: var(--space-16);
    background: var(--gradient-card);
    border-radius: var(--radius-xl);
    border: 1px solid rgba(79, 125, 247, 0.2);
  }

  .bottom-cta-heading {
    font-size: var(--text-3xl);
    font-weight: var(--font-black);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-4) 0;
    line-height: var(--leading-tight);
  }

  .bottom-cta-text {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto var(--space-8) auto;
    line-height: var(--leading-relaxed);
  }

  /* === RESPONSIVE === */
  @media (max-width: 1024px) {
    .service-header {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .service-number {
      font-size: var(--text-7xl);
      justify-self: center;
      min-width: auto;
    }

    .service-title-group {
      align-items: center;
    }
  }

  @media (max-width: 768px) {
    .page-title {
      font-size: var(--text-4xl);
    }

    .service-title {
      font-size: var(--text-3xl);
    }

    .service-number {
      font-size: var(--text-6xl);
    }

    .service-benefits {
      padding: var(--space-6);
    }

    .benefits-heading {
      font-size: var(--text-xl);
    }

    .bottom-cta {
      padding: var(--space-12);
    }

    .bottom-cta-heading {
      font-size: var(--text-2xl);
    }

    .service-cta {
      flex-direction: column;
    }
  }

  @media (max-width: 480px) {
    .page-title {
      font-size: var(--text-3xl);
    }

    .service-title {
      font-size: var(--text-2xl);
    }

    .service-description {
      font-size: var(--text-lg);
    }

    .service-number {
      font-size: var(--text-5xl);
    }

    .benefit-item {
      flex-direction: column;
      gap: var(--space-2);
    }
  }
</style>
