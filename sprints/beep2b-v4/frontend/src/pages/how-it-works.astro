---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import Badge from '../components/Badge.astro';
import Button from '../components/Button.astro';
import SectionDivider from '../components/SectionDivider.astro';

// BEEP methodology steps with detailed content
const beepSteps = [
  {
    number: '01',
    letter: 'B',
    title: 'Build',
    color: 'primary',
    description: 'Grow your LinkedIn network with precision-targeted connections to your ideal customer profile',
    details: 'We identify decision-makers in your exact niche using advanced LinkedIn search strategies, filtering by industry, company size, role, and engagement patterns. Each connection request is strategically timed and personalized to maximize acceptance rates.',
    highlight: 'Precision Targeting'
  },
  {
    number: '02',
    letter: 'E',
    title: 'Engage',
    color: 'accent',
    description: 'Foster meaningful one-to-one conversations based on prospects\' goals, interests, and pain points',
    details: 'Genuine relationship building through personalized messages that reference the prospect\'s recent posts, shared connections, or industry challenges. No templates, no spam — just authentic human conversation at scale.',
    highlight: 'Relationship-First'
  },
  {
    number: '03',
    letter: 'E',
    title: 'Educate',
    color: 'secondary',
    description: 'Deliver high-value content that establishes you as a trusted authority in your niche',
    details: 'Strategic content publishing that addresses your prospects\' real questions and pain points. We help you share insights, case studies, and thought leadership pieces that position you as the go-to expert before the sales conversation even begins.',
    highlight: 'Authority Building'
  },
  {
    number: '04',
    letter: 'P',
    title: 'Promote',
    color: 'warning',
    description: 'Share offerings to a warmed, trusting audience that already sees your value',
    details: 'When prospects already know, like, and trust you, the sales conversation becomes natural. We help you introduce your services to an audience that\'s been primed to say yes, resulting in higher conversion rates and shorter sales cycles.',
    highlight: 'Natural Conversion'
  }
];

// Why BEEP Works differentiators
const differentiators = [
  {
    title: 'Not Another Cold Outreach Tool',
    description: 'BEEP is a relationship-first methodology, not a spray-and-pray automation. We focus on building genuine connections that turn into long-term business relationships, not just one-time transactions.',
    icon: '🤝'
  },
  {
    title: 'Systematic & Repeatable',
    description: 'Every step is documented, measurable, and teachable. You\'ll know exactly what to do each day, what results to expect, and how to scale the system across your entire sales team.',
    icon: '📊'
  },
  {
    title: 'Proven Across 22 Countries',
    description: 'Over 500 clients from startups to enterprise teams have used BEEP to generate consistent B2B leads. The methodology works across industries, geographies, and deal sizes — because it\'s built on timeless relationship principles.',
    icon: '🌍'
  }
];
---

<BaseLayout title="How It Works - The BEEP Methodology | Beep2B">
  <!-- Hero Banner -->
  <Section>
    <div class="page-hero" data-animate="fade-in">
      <Badge variant="primary">Our Methodology</Badge>
      <h1 class="page-title">How It Works</h1>
      <p class="page-intro">
        The BEEP framework is a proven 4-step system that transforms LinkedIn from a networking tool into a predictable lead generation engine. No spam, no cold pitches — just systematic relationship building that delivers results.
      </p>
    </div>
  </Section>

  <SectionDivider />

  <!-- BEEP Steps - Alternating Layout -->
  <Section>
    <div class="beep-steps-detailed">
      {beepSteps.map((step, index) => (
        <div class={`beep-step-detailed ${index % 2 === 0 ? 'layout-left' : 'layout-right'}`} data-animate="fade-in">
          <div class="step-visual">
            <div class="step-number">{step.number}</div>
            <Badge variant={step.color} size="large">{step.letter}</Badge>
          </div>
          <div class="step-content">
            <div class="step-highlight">
              <Badge variant={step.color}>{step.highlight}</Badge>
            </div>
            <h2 class="step-title">{step.title}</h2>
            <p class="step-description">{step.description}</p>
            <p class="step-details">{step.details}</p>
          </div>
        </div>
      ))}
    </div>
  </Section>

  <SectionDivider variant="thick" />

  <!-- Why BEEP Works -->
  <Section label="Why It Works" background="elevated">
    <h2 class="section-heading" data-animate="slide-up">
      Why BEEP Works When Other Approaches Fail
    </h2>
    <p class="section-intro" data-animate="slide-up">
      Most LinkedIn lead generation strategies focus on volume and automation. BEEP focuses on relationship quality and systematic execution — and that makes all the difference.
    </p>
    <div class="differentiators-grid" data-stagger>
      {differentiators.map(diff => (
        <Card animate="fade-in">
          <div class="differentiator-card">
            <div class="diff-icon">{diff.icon}</div>
            <h3 class="diff-title">{diff.title}</h3>
            <p class="diff-description">{diff.description}</p>
          </div>
        </Card>
      ))}
    </div>
  </Section>

  <SectionDivider />

  <!-- CTA Section -->
  <Section>
    <div class="cta-box" data-animate="fade-in">
      <h2 class="cta-heading">Ready to Implement BEEP in Your Business?</h2>
      <p class="cta-text">
        Book a discovery call to learn how we can customize the BEEP methodology for your industry, audience, and sales cycle.
      </p>
      <div class="cta-buttons">
        <Button href="/contact" variant="primary" size="large">Book a Discovery Call</Button>
        <Button href="/services" variant="secondary" size="large">View Our Services</Button>
      </div>
    </div>
  </Section>
</BaseLayout>

<style>
  /* === PAGE HERO === */
  .page-hero {
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
    padding: var(--space-12) 0;
  }

  .page-title {
    font-size: var(--font-size-5xl);
    font-weight: var(--font-weight-black);
    color: var(--color-text-primary);
    margin: var(--space-4) 0;
    line-height: var(--line-height-tight);
    letter-spacing: var(--letter-spacing-tight);
  }

  .page-intro {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    margin: 0;
  }

  /* === BEEP STEPS DETAILED === */
  .beep-steps-detailed {
    display: flex;
    flex-direction: column;
    gap: var(--space-16);
  }

  .beep-step-detailed {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--space-12);
    align-items: center;
    padding: var(--space-12);
    background: var(--gradient-card);
    border-radius: var(--radius-xl);
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: all var(--transition-base);
  }

  .beep-step-detailed:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: rgba(79, 125, 247, 0.3);
  }

  .beep-step-detailed.layout-right {
    grid-template-columns: 2fr 1fr;
  }

  .beep-step-detailed.layout-right .step-visual {
    order: 2;
  }

  .beep-step-detailed.layout-right .step-content {
    order: 1;
  }

  .step-visual {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
    padding: var(--space-8);
  }

  .step-number {
    font-size: var(--font-size-6xl);
    font-weight: var(--font-weight-black);
    color: rgba(79, 125, 247, 0.2);
    line-height: 1;
    text-align: center;
  }

  .step-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .step-highlight {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .step-title {
    font-size: var(--font-size-4xl);
    font-weight: var(--font-weight-black);
    color: var(--color-text-primary);
    margin: 0;
    line-height: var(--line-height-tight);
  }

  .step-description {
    font-size: var(--font-size-xl);
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    margin: 0;
    font-weight: var(--font-weight-medium);
  }

  .step-details {
    font-size: var(--font-size-base);
    color: var(--color-text-muted);
    line-height: var(--line-height-relaxed);
    margin: 0;
  }

  /* === SECTION STYLING === */
  .section-heading {
    font-size: var(--font-size-4xl);
    font-weight: var(--font-weight-black);
    color: var(--color-text-primary);
    text-align: center;
    margin: 0 0 var(--space-6) 0;
    line-height: var(--line-height-tight);
    letter-spacing: var(--letter-spacing-tight);
  }

  .section-intro {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    text-align: center;
    max-width: 700px;
    margin: 0 auto var(--space-12) auto;
    line-height: var(--line-height-relaxed);
  }

  /* === DIFFERENTIATORS GRID === */
  .differentiators-grid {
    display: grid;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .differentiators-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .differentiators-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .differentiator-card {
    padding: var(--space-8);
    text-align: center;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .diff-icon {
    font-size: var(--font-size-5xl);
    line-height: 1;
  }

  .diff-title {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text-primary);
    margin: 0;
    line-height: var(--line-height-tight);
  }

  .diff-description {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    margin: 0;
  }

  /* === CTA BOX === */
  .cta-box {
    text-align: center;
    padding: var(--space-16);
    background: var(--gradient-card);
    border-radius: var(--radius-xl);
    border: 1px solid rgba(79, 125, 247, 0.2);
  }

  .cta-heading {
    font-size: var(--font-size-3xl);
    font-weight: var(--font-weight-black);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-4) 0;
    line-height: var(--line-height-tight);
  }

  .cta-text {
    font-size: var(--font-size-lg);
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto var(--space-8) auto;
    line-height: var(--line-height-relaxed);
  }

  .cta-buttons {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  /* === RESPONSIVE === */
  @media (max-width: 1024px) {
    .beep-step-detailed {
      grid-template-columns: 1fr;
    }

    .beep-step-detailed.layout-right {
      grid-template-columns: 1fr;
    }

    .beep-step-detailed.layout-right .step-visual {
      order: 1;
    }

    .beep-step-detailed.layout-right .step-content {
      order: 2;
    }

    .step-visual {
      padding: var(--space-4);
    }

    .step-number {
      font-size: var(--font-size-5xl);
    }
  }

  @media (max-width: 768px) {
    .page-title {
      font-size: var(--font-size-4xl);
    }

    .section-heading {
      font-size: var(--font-size-3xl);
    }

    .step-title {
      font-size: var(--font-size-3xl);
    }

    .cta-heading {
      font-size: var(--font-size-2xl);
    }

    .beep-steps-detailed {
      gap: var(--space-8);
    }

    .beep-step-detailed {
      padding: var(--space-6);
      gap: var(--space-6);
    }

    .differentiators-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .page-title {
      font-size: var(--font-size-3xl);
    }

    .cta-buttons {
      flex-direction: column;
      width: 100%;
    }

    .step-description {
      font-size: var(--font-size-lg);
    }
  }
</style>
