---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <main>
    <section style="min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 2rem;">
      <div style="text-align: center; max-width: 800px;">
        <h1 style="font-size: 3rem; font-weight: 700; margin-bottom: 1rem;">
          Beep2B
        </h1>
        <p style="font-size: 1.5rem; color: #b0b0c0; margin-bottom: 2rem;">
          Consistent B2B Leads From LinkedIn
        </p>
        <p style="color: #6b6b80;">
          This is a placeholder page. The Beep2B marketing website is being built with Astro 5, React, and Payload CMS.
        </p>
      </div>
    </section>
  </main>
</BaseLayout>
